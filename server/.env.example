NODE_ENV=development
APP_ENV=development
PORT=3001
CLIENT_ORIGINS=*
DATA_DIR=./data

# Development uses JSON persistence unless DATABASE_URL is set.
DATABASE_URL=
DATABASE_SSL=0

# Public URLs shown to clients/admin tools.
PUBLIC_API_URL=http://localhost:3001
ADMIN_PUBLIC_URL=http://localhost:3001/admin

# Pre-alpha / staging invite gate.
REQUIRE_INVITE_CODE=0

# Local-only bootstrap helpers. Keep disabled in staging/production.
SEED_ADMIN_ACCOUNT=1
SEED_TEST_ACCOUNTS=1
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me
ADMIN_BOOTSTRAP_MFA_CODE=000000
