{
  "root": true,
  "extends": [
    "universe/native",
    "universe/shared/typescript-analysis"
  ],
  "parserOptions": {
    "project": "./tsconfig.json",
    "tsconfigRootDir": "."
  },
  "rules": {
    "react-hooks/exhaustive-deps": "off"
  },
  "ignorePatterns": [
    "node_modules/",
    ".expo/"
  ]
}
