{
  "expo": {
    "name": "Golf 9",
    "slug": "golf9",
    "scheme": "golf9",
    "version": "0.1.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "sdkVersion": "53.0.0",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
