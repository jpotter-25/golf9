{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_APP_ENV": "development" }
    },
    "staging": {
      "distribution": "internal",
      "env": { "EXPO_PUBLIC_APP_ENV": "staging" },
      "ios": { "simulator": false },
      "android": { "buildType": "apk" }
    },
    "production": {
      "env": { "EXPO_PUBLIC_APP_ENV": "production" },
      "android": { "buildType": "app-bundle" }
    }
  },
  "submit": {
    "production": {}
  }
}
